# =============================================
# JWT Configuration
# =============================================
# Base64-encoded HMAC secret key (required)
JWT_SECRET=your-base64-encoded-secret-here
# Token expiration in milliseconds (default: 86400000 = 24h)
JWT_EXPIRATION=86400000

# =============================================
# Database Configuration
# =============================================
DATASOURCE_URL=jdbc:h2:mem:bankingdb
DATASOURCE_DRIVER=org.h2.Driver
DATASOURCE_USERNAME=sa
DATASOURCE_PASSWORD=
JPA_PLATFORM=org.hibernate.dialect.H2Dialect
H2_CONSOLE_ENABLED=true

# =============================================
# Seed Credentials
# =============================================
SEED_EMPLOYEE_EMAIL=employee@bank.com
SEED_EMPLOYEE_PASSWORD=change-me
SEED_CUSTOMER_EMAIL=customer@test.com
SEED_CUSTOMER_PASSWORD=change-me
SEED_CUSTOMER2_EMAIL=customer2@test.com
SEED_CUSTOMER2_PASSWORD=change-me
SEED_CUSTOMER3_EMAIL=customer3@test.com
SEED_CUSTOMER3_PASSWORD=change-me
SEED_PENDING1_EMAIL=daan.bakker@test.com
SEED_PENDING1_PASSWORD=change-me
SEED_PENDING2_EMAIL=lotte.visser@test.com
SEED_PENDING2_PASSWORD=change-me
SEED_PENDING3_EMAIL=thijs.smit@test.com
SEED_PENDING3_PASSWORD=change-me
SEED_PENDING4_EMAIL=fenna.mulder@test.com
SEED_PENDING4_PASSWORD=change-me

# =============================================
# CORS
# =============================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# =============================================
# Server Configuration
# =============================================
SERVER_PORT=8080
